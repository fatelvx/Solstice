{
    "packages": {
        ".": {
            "release-type": "rust",
            "changelog-path": "CHANGELOG.md",
            "bump-minor-pre-major": true,
            "bump-patch-for-minor-pre-major": true,
            "draft": false,
            "prerelease": false,
            "extra-files": [
                {
                    "type": "json",
                    "path": "src-tauri/tauri.conf.json",
                    "jsonpath": "$.version"
                },
                {
                    "type": "json",
                    "path": "package.json",
                    "jsonpath": "$.version"
                }
            ]
        }
    },
    "changelog-sections": [
        { "type": "feat", "section": "✨ New Features", "hidden": false },
        { "type": "fix", "section": "🐞 Bug Fixes", "hidden": false },
        { "type": "perf", "section": "🛠 Improvements", "hidden": false },
        { "type": "refactor", "section": "🔧 Under the Hood", "hidden": false },
        { "type": "chore", "section": "🔧 Under the Hood", "hidden": false }
    ]
}
